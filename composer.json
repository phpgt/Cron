{
	"name": "phpgt/cron",
	"description": "Run scripts or static functions at regular intervals.",

	"require": {
		"php": ">=8.1",
		"phpgt/cli": "1.*",
		"phpgt/config": "^1.1",
		"phpgt/input": "^1.3",
		"phpgt/servicecontainer": "^1.3"
	},
	"require-dev": {
		"phpstan/phpstan": "^1.10",
		"phpunit/phpunit": "^10.1",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^3.7"
	},

	"autoload": {
		"psr-4": {
			"Gt\\Cron\\": "./src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Gt\\Cron\\Test\\": "./test/phpunit/"
		}
	},

	"bin": [
		"bin/cron"
	],

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
